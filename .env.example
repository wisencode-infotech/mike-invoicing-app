APP_NAME="Invoicing App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------
# Database (MySQL)
# ------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=invoicing_app
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ------------------------------------------------------------------
# Queue — database driver for a single VPS; swap to redis later if needed.
# Run: php artisan queue:work --sleep=3 --tries=3 --timeout=120
# ------------------------------------------------------------------
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------
# Mail — provider swappable without code changes (smtp/mailgun/ses/sendgrid via smtp).
# Use MAIL_MAILER=log locally to inspect outgoing mail in storage/logs/laravel.log.
# ------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="billing@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------
# Square Payments — see docs/ARCHITECTURE.md section 11 and SquarePaymentService.
# Sandbox credentials pending from client; keep SQUARE_ENV=sandbox until go-live.
#
# SQUARE_ENV                    "sandbox" or "production". Never point at
#                                production without confirming live credentials.
# SQUARE_ACCESS_TOKEN            Personal access token (or OAuth token) from
#                                the Square Developer Dashboard > your app >
#                                Sandbox/Production > Access token. Treat as a
#                                secret — never commit, log, or display it.
# SQUARE_LOCATION_ID              The Location ID payments are recorded
#                                against (Developer Dashboard > Locations).
# SQUARE_APPLICATION_ID           Public app ID, safe to expose client-side if
#                                ever needed (e.g. Web Payments SDK).
# SQUARE_WEBHOOK_SIGNATURE_KEY     Used to verify incoming webhook signatures
#                                (wired up in Phase 12) — also a secret.
# SQUARE_CURRENCY                ISO 4217 currency code invoices are created in.
#
# There is no SQUARE_CHECKOUT_REDIRECT_URL — after paying, Square redirects
# the customer back to their own branded portal page
# (route('portal.show', $token)), generated per payment link automatically.
# That page is always display-only; only the Phase 12 webhook may mark an
# invoice paid.
# ------------------------------------------------------------------
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_APPLICATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_CURRENCY=USD

# ------------------------------------------------------------------
# SMS — provider-agnostic behind App\Services\Sms\SmsService. Twilio is the
# default/recommended provider (see docs/ARCHITECTURE.md section 5).
# ------------------------------------------------------------------
SMS_PROVIDER=twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ------------------------------------------------------------------
# Customer Portal — token-secured invoice/payment pages, no login required.
# ------------------------------------------------------------------
PORTAL_TOKEN_LENGTH=48
PORTAL_RATE_LIMIT_PER_MINUTE=30

# ------------------------------------------------------------------
# Invoicing defaults — used by InvoiceNumberService / InvoiceService.
# ------------------------------------------------------------------
INVOICE_NUMBER_PREFIX=INV-
INVOICE_NUMBER_PADDING=6
INVOICE_DEFAULT_DUE_DAYS=14
RECEIPT_NUMBER_PREFIX=RCPT-
RECEIPT_NUMBER_PADDING=6

VITE_APP_NAME="${APP_NAME}"
